   "source": [
    "# Write a python programme to display even numbers between 1 to 10. Also print \"We have "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "ae3708d6-90c9-443e-8374-ede060cb532a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "2\n",
      "4\n",
      "6\n",
      "8\n",
      "We have 4 even numbers\n"
     ]
    }
   ],
   "source": [
    "count = 0\n",
    "for i in range(1,10):\n",
    "    if i%2 == 0:\n",
    "        print (i)\n",
    "        count += 1\n",
    "\n",
    "print(\"We have\",count,\"even numbers\")"
   ]
